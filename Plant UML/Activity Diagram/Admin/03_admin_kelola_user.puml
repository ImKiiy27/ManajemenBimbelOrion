@startuml
title Activity Diagram - Admin Kelola User

skinparam activity {
  BackgroundColor #F8FBFF
  BorderColor #2F4F8F
  FontColor #1F2937
}

start

partition "Admin" {
    :Admin membuka halaman login;
    :Admin memasukkan email dan password;
    :Admin klik tombol Login;
}

partition "Sistem" {
    :Memeriksa data login admin;
}

if (Login valid?) then (Ya)


    partition "Admin" {
        :Admin masuk ke dashboard;
        :Admin memilih menu Kelola User;
    }

    partition "Sistem" {
        :Menampilkan data user;
        :Menampilkan form tambah user;
    }

    partition "Admin" {
        :Admin melihat data user;
    }

    if (Admin ingin mengelola user?) then (Ya)

        partition "Admin" {
            :Admin memilih aksi user;
        }

        if (Aksi yang dipilih?) then (Tambah / Edit)

            partition "Admin" {
                :Admin mengisi email;
                :Admin mengisi password jika diperlukan;
                :Admin memilih role user;
                :Admin mengisi nama jika diperlukan;
                :Admin mengisi kelas jika role siswa;
                :Admin klik tombol Simpan / Proses;
            }

            partition "Sistem" {
                :Memeriksa data user;
            }

            if (Data user valid?) then (Ya)
                partition "Sistem" {
                    :Menyimpan perubahan data user;
                    :Menampilkan pesan berhasil;
                    :Menampilkan kembali data user dan form;
                }
            else (Tidak)
                partition "Sistem" {
                    :Menampilkan pesan error;
                    :Menampilkan kembali data user dan form;
                }
            endif

        elseif (Hapus User)

            partition "Admin" {
                :Admin memilih user yang akan dihapus;
                :Admin melakukan konfirmasi hapus;
            }

            partition "Sistem" {
                :Memeriksa data user dan relasinya;
            }

            if (User dapat dihapus?) then (Ya)
                partition "Sistem" {
                    :Menghapus data user;
                    :Menampilkan pesan berhasil;
                    :Menampilkan kembali data user dan form;
                }
            else (Tidak)
                partition "Sistem" {
                    :Menampilkan pesan error;
                    :Menampilkan kembali data user dan form;
                }
            endif

        else (Buka Kunci Akun)

            partition "Admin" {
                :Admin memilih user yang terkunci;
                :Admin klik tombol buka kunci;
            }

            partition "Sistem" {
                :Mereset status kunci akun dan percobaan login;
                :Menampilkan pesan berhasil;
                :Menampilkan kembali data user dan form;
            }

        endif

    else (Tidak)

        partition "Admin" {
            :Admin tidak melakukan perubahan user;
        }

    endif

else (Tidak)

    partition "Sistem" {
        :Menampilkan pesan login gagal;
    }

    partition "Admin" {
        :Admin kembali ke halaman login;
    }

endif

stop
@enduml
