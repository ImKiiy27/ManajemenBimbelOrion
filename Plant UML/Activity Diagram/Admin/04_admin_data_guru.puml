@startuml
title Activity Diagram - Admin Mengelola Data Guru

skinparam activity {
  BackgroundColor #F8FBFF
  BorderColor #2F4F8F
  FontColor #1F2937
}

start

partition "Admin" {
    :Admin membuka halaman login;
    :Admin memasukkan email dan password;
    :Admin klik tombol Login;
}

partition "Sistem" {
    :Memeriksa data login admin;
}

if (Login valid?) then (Ya)


    partition "Admin" {
        :Admin masuk ke dashboard;
        :Admin memilih menu Data Guru;
    }

    partition "Sistem" {
        :Menampilkan data guru;
        :Menampilkan ringkasan data guru;
        :Menampilkan form edit data guru;
    }

    partition "Admin" {
        :Admin melihat data guru;
    }

    if (Admin ingin mengubah data guru?) then (Ya)

        partition "Admin" {
            :Admin memilih guru yang akan diedit;
            :Admin mengubah nama guru;
            :Admin memilih mapel utama guru;
            :Admin klik tombol Simpan Perubahan;
        }

        partition "Sistem" {
            :Memeriksa data guru;
        }

        if (Data guru valid?) then (Ya)
            partition "Sistem" {
                :Menyimpan perubahan data guru;
                :Menampilkan pesan berhasil;
                :Menampilkan kembali data guru dan form;
            }
        else (Tidak)
            partition "Sistem" {
                :Menampilkan pesan error;
                :Menampilkan kembali data guru dan form;
            }
        endif

    else (Tidak)

        partition "Admin" {
            :Admin tidak melakukan perubahan data guru;
        }

    endif

else (Tidak)

    partition "Sistem" {
        :Menampilkan pesan login gagal;
    }

    partition "Admin" {
        :Admin kembali ke halaman login;
    }

endif

stop
@enduml
