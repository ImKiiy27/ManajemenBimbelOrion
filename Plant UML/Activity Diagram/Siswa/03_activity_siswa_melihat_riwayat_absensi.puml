@startuml
title Activity Diagram - Siswa Melihat Riwayat Absensi

start

partition "Siswa" {
    :Siswa membuka halaman login;
    :Siswa memasukkan username dan password;
    :Siswa klik tombol Login;
}

partition "Sistem" {
    :Memeriksa data login siswa;
}

if (Login valid?) then (Ya)

    partition "Siswa" {
        :Siswa masuk ke dashboard;
        :Siswa memilih menu Absensi;
    }

    partition "Sistem" {
        :Menampilkan halaman Riwayat Absensi;
        :Menampilkan ringkasan total absensi;
        :Menampilkan jumlah Hadir, Izin + Sakit,
dan Alpa;
        :Menampilkan filter tanggal;
    }

    if (Data absensi tersedia?) then (Ya)

        partition "Sistem" {
            :Menampilkan tabel riwayat absensi;
            :Menampilkan tanggal, hari, jam,
guru, status, dan alasan;
        }

    else (Tidak)

        partition "Sistem" {
            :Menampilkan pesan tidak ada data absensi;
        }

    endif

    partition "Siswa" {
        :Siswa melihat riwayat absensi;
    }

    if (Siswa ingin memfilter tanggal?) then (Ya)

        partition "Siswa" {
            :Siswa mengisi tanggal dari;
            :Siswa mengisi tanggal sampai;
            :Siswa klik tombol Filter;
        }

        partition "Sistem" {
            :Memeriksa rentang tanggal;
        }

        if (Rentang tanggal valid?) then (Ya)

            partition "Sistem" {
                :Menampilkan ulang ringkasan absensi;
                :Menampilkan riwayat absensi
sesuai filter tanggal;
            }

        else (Tidak)

            partition "Sistem" {
                :Menampilkan pesan error;
                :Menampilkan kembali halaman absensi
dan filter tanggal;
            }

        endif

    else (Tidak)

        partition "Siswa" {
            :Siswa tidak melakukan filter;
        }

    endif

else (Tidak)

    partition "Sistem" {
        :Menampilkan pesan login gagal;
    }

    partition "Siswa" {
        :Siswa kembali ke halaman login;
    }

endif

stop

@enduml
