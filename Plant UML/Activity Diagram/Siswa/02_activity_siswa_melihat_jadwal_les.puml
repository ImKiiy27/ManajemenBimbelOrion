@startuml
title Activity Diagram - Siswa Melihat Jadwal Les

start

partition "Siswa" {
    :Siswa membuka halaman login;
    :Siswa memasukkan username dan password;
    :Siswa klik tombol Login;
}

partition "Sistem" {
    :Memeriksa data login siswa;
}

if (Login valid?) then (Ya)

    partition "Siswa" {
        :Siswa masuk ke dashboard;
        :Siswa memilih menu Jadwal Les;
    }

    partition "Sistem" {
        :Mengambil jadwal les milik siswa;
        :Menampilkan halaman Jadwal Les Saya;
        :Menampilkan total jadwal;
    }

    if (Jadwal les tersedia?) then (Ya)

        partition "Sistem" {
            :Menampilkan tabel jadwal les;
            :Menampilkan hari, jam, guru,
mapel siswa, dan mapel guru;
        }

        partition "Siswa" {
            :Siswa melihat jadwal les;
        }

    else (Tidak)

        partition "Sistem" {
            :Menampilkan pesan belum ada jadwal les;
        }

        partition "Siswa" {
            :Siswa mengetahui bahwa jadwal belum tersedia;
        }

    endif

else (Tidak)

    partition "Sistem" {
        :Menampilkan pesan login gagal;
    }

    partition "Siswa" {
        :Siswa kembali ke halaman login;
    }

endif

stop

@enduml
