@startuml
title Activity Diagram - Guru Mengelola Profil Saya

start

partition "Guru" {
    :Guru membuka halaman login;
    :Guru memasukkan username dan password;
    :Guru klik tombol Login;
}

partition "Sistem" {
    :Memeriksa data login guru;
}

if (Login valid?) then (Ya)

    partition "Guru" {
        :Guru masuk ke dashboard;
        :Guru memilih menu Profil;
    }

    partition "Sistem" {
        :Menampilkan halaman Profil Saya;
        :Menampilkan biodata guru;
        :Menampilkan form Ubah Profil;
        :Menampilkan form Ganti Password;
        :Menampilkan Jadwal Mengajar Ringkas;
    }

    partition "Guru" {
        :Guru melihat data profil;
    }

    if (Guru ingin mengubah profil?) then (Ya)

        partition "Guru" {
            :Guru mengubah nama lengkap, email,
no. telepon, alamat, atau bio;
            :Guru klik tombol Simpan Profil;
        }

        partition "Sistem" {
            :Memeriksa data profil;
        }

        if (Data profil valid?) then (Ya)
            partition "Sistem" {
                :Menyimpan perubahan profil;
                :Menampilkan pesan berhasil;
                :Menampilkan kembali halaman Profil Saya;
            }
        else (Tidak)
            partition "Sistem" {
                :Menampilkan pesan error;
                :Menampilkan kembali halaman Profil Saya;
            }
        endif

    else (Tidak)

        if (Guru ingin mengganti password?) then (Ya)

            partition "Guru" {
                :Guru mengisi password saat ini;
                :Guru mengisi password baru;
                :Guru mengisi konfirmasi password baru;
                :Guru klik tombol Update Password;
            }

            partition "Sistem" {
                :Memeriksa data password;
            }

            if (Data password valid?) then (Ya)
                partition "Sistem" {
                    :Menyimpan password baru;
                    :Menampilkan pesan berhasil;
                    :Menampilkan kembali halaman Profil Saya;
                }
            else (Tidak)
                partition "Sistem" {
                    :Menampilkan pesan error;
                    :Menampilkan kembali halaman Profil Saya;
                }
            endif

        else (Tidak)

            partition "Guru" {
                :Guru tidak melakukan perubahan profil;
            }

        endif

    endif

else (Tidak)

    partition "Sistem" {
        :Menampilkan pesan login gagal;
    }

    partition "Guru" {
        :Guru kembali ke halaman login;
    }

endif

stop

@enduml
