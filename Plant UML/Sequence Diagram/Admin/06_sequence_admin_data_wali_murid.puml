@startuml 06_sequence_admin_data_wali_murid
title Sequence Diagram - Admin Data Wali Murid
hide footbox
autonumber
skinparam shadowing false
skinparam sequence {
  ArrowColor #2F4F8F
  LifeLineBorderColor #6B7280
  LifeLineBackgroundColor #F9FAFB
  ParticipantBorderColor #2F4F8F
  ParticipantBackgroundColor #F8FBFF
  ActorBorderColor #111827
  ActorBackgroundColor #FFFFFF
  BoxBorderColor #CBD5E1
  BoxBackgroundColor #FFFFFF
}


actor "Admin" as Admin
boundary "Halaman Sistem" as Halaman
control "Sistem BimbelOrion" as Sistem
database "Database" as Database

Admin -> Halaman: Buka menu Data Wali Murid
Halaman -> Sistem: Meminta halaman admin wali murid
Sistem -> Sistem: Memastikan hak aksesnya admin
Sistem -> Database: Mengambil data wali_murid beserta status akun
Database --> Sistem: Mengirim daftar wali
Sistem --> Halaman: Mengirim hasil ke halaman
Halaman --> Admin: Menampilkan hasil kepada pengguna
opt Admin melihat siswa terhubung
  Admin -> Halaman: Klik lihat siswa
  Halaman -> Sistem: Mengirim permintaan ke sistem
  Sistem -> Database: Mengambil data siswa WHERE wali_id=?
  Database --> Sistem: Mengirim daftar siswa anak
  Sistem --> Halaman: Mengirim hasil ke halaman
  Halaman --> Admin: Tampilkan daftar siswa terhubung
end
opt Admin tambah / edit / buat akun / hapus wali
  Admin -> Halaman: Mengirim form wali
  Halaman -> Sistem: Mengirim data formulir admin wali murid
  Sistem -> Sistem: Memeriksa kode keamanan formulir
  alt kode keamanan formulir tidak benar
    Sistem --> Halaman: Mengirim hasil gagal
  else kode keamanan formulir benar
    alt create-wali
      Sistem -> Database: Menyimpan data baru wali_murid
    else create-wali-account
      Sistem -> Database: Menyimpan data baru users hak akses wali_murid
    else update-wali
      Sistem -> Database: Memperbarui data wali_murid
    else delete-wali
      Sistem -> Sistem: Menghapus wali murid
      Sistem -> Database: Mengolah data di database
    else delete-wali-force
      Sistem -> Sistem: Force menghapus wali murid
      Sistem -> Database: Mengolah data di database
    end
    Database --> Sistem: Mengirim hasil proses
    Sistem --> Halaman: Mengalihkan page=admin-wali-murid
    Halaman --> Admin: Menampilkan pesan dan data terbaru
  end
@enduml
