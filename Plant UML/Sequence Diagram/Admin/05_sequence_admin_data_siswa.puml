@startuml 05_sequence_admin_data_siswa
title Sequence Diagram - Admin Data Siswa
hide footbox
autonumber
skinparam shadowing false
skinparam sequence {
  ArrowColor #2F4F8F
  LifeLineBorderColor #6B7280
  LifeLineBackgroundColor #F9FAFB
  ParticipantBorderColor #2F4F8F
  ParticipantBackgroundColor #F8FBFF
  ActorBorderColor #111827
  ActorBackgroundColor #FFFFFF
  BoxBorderColor #CBD5E1
  BoxBackgroundColor #FFFFFF
}


actor "Admin" as Admin
boundary "Halaman Sistem" as Halaman
control "Sistem BimbelOrion" as Sistem
database "Database" as Database

Admin -> Halaman: Buka menu Data Siswa
Halaman -> Sistem: Meminta halaman admin siswa
Sistem -> Sistem: Memastikan hak aksesnya admin
Sistem -> Database: Mengambil data siswa JOIN users LEFT JOIN wali_murid
Database --> Sistem: Mengirim daftar siswa
Sistem -> Database: Mengambil data mapel aktif
Database --> Sistem: Mengirim hasil data
Sistem -> Database: Mengambil data wali_murid
Database --> Sistem: Mengirim hasil data
loop Untuk tiap siswa
  Sistem -> Database: Mengambil data siswa_mapel
  Database --> Sistem: Mengirim hasil data
end
Sistem --> Halaman: Mengirim hasil ke halaman
Halaman --> Admin: Menampilkan hasil kepada pengguna
opt Admin mengubah profil/mapel/wali siswa
  Admin -> Halaman: Submit ubah-siswa
  Halaman -> Sistem: Mengirim data formulir admin siswa
  Sistem -> Sistem: Memeriksa kode keamanan formulir
  alt kode keamanan formulir tidak benar
    Sistem --> Halaman: Mengirim hasil gagal
  else kode keamanan formulir benar
    Sistem -> Database: Mengolah data di database
    Database --> Sistem: Hasil benarasi
    alt Data benar
      Sistem -> Database: Memperbarui data siswa
      Sistem -> Database: Mengolah data di database
      Database --> Sistem: Mengirim hasil data
    else Data tidak benar
    end
    Sistem --> Sistem: Menyiapkan pesan untuk pengguna
    Sistem --> Halaman: Mengalihkan page=admin-siswa
    Halaman --> Admin: Menampilkan pesan dan data terbaru
  end
@enduml
