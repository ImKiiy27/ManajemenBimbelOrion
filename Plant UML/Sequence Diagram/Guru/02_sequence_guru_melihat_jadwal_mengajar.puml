@startuml 02_sequence_guru_melihat_jadwal_mengajar
title Sequence Diagram - Guru Melihat Jadwal Mengajar
hide footbox
autonumber
skinparam shadowing false
skinparam sequence {
  ArrowColor #2F4F8F
  LifeLineBorderColor #6B7280
  LifeLineBackgroundColor #F9FAFB
  ParticipantBorderColor #2F4F8F
  ParticipantBackgroundColor #F8FBFF
  ActorBorderColor #111827
  ActorBackgroundColor #FFFFFF
  BoxBorderColor #CBD5E1
  BoxBackgroundColor #FFFFFF
}


actor "Guru" as Guru
boundary "Halaman Sistem" as Halaman
control "Sistem BimbelOrion" as Sistem
database "Database" as Database

Guru -> Halaman: Buka menu Jadwal Mengajar
Halaman -> Sistem: Meminta halaman guru jadwal
Sistem -> Sistem: Memastikan hak aksesnya guru
Sistem -> Database: Mengambil data jadwal berdasarkan guru
Database --> Sistem: Mengirim daftar jadwal
Sistem --> Halaman: Mengirim hasil ke halaman
Halaman --> Guru: Menampilkan hasil kepada pengguna
@enduml
