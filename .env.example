# ============================================================
# Contoh konfigurasi environment untuk Bimbel Orion
# Salin file ini menjadi ".env" lalu sesuaikan nilainya.
# ============================================================

# Database
DB_HOST=localhost
DB_NAME=nama_database
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Aplikasi
APP_NAME="Bimbel Orion"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/ManajemenBimbel
